# WingmanEM — environment variables (reference)
# Copy to `.env` for generic local use, or use `.env.development` with
# `scripts/with_dev_env.sh` (see DEPLOYMENT.md).
# Never commit real secrets; `.env` and `.env.development` are gitignored.

# =============================================================================
# REQUIRED FOR PRODUCTION (web)
# =============================================================================

# Flask session and cookie signing. Keep secret and stable across restarts.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# If unset, the app uses a random secret each process start (not suitable for
# production or multiple Gunicorn workers with sticky expectations).
SECRET_KEY=

# =============================================================================
# OPTIONAL — Web (Flask)
# =============================================================================

# WINGMANEM_MAX_UPLOAD_MB=32
# WINGMANEM_WEB_HOST=127.0.0.1
# WINGMANEM_WEB_PORT=5000
# WINGMANEM_WEB_DEBUG=false

# =============================================================================
# OPTIONAL — AI (Mistral)
# =============================================================================

# Requires the mistralai package in the same venv as the app (pip install -r requirements.txt).
# MISTRAL_API_KEY=

# =============================================================================
# OPTIONAL — CLI
# =============================================================================

# WINGMANEM_PASSWORD=
# WINGMANEM_DEBUG=

# =============================================================================
# OPTIONAL — Data paths (defaults are filenames under cwd)
# =============================================================================

# WINGMANEM_DATABASE_PATH=wingmanem.db
# WINGMANEM_DIRECT_REPORTS_FILE=direct_reports.json
# WINGMANEM_MANAGEMENT_TIPS_FILE=management_tips.json
# WINGMANEM_DIRECT_REPORT_GOALS_FILE=direct_report_goals.json
# WINGMANEM_DIRECT_REPORT_COMP_DATA_FILE=direct_report_comp_data.json
# WINGMANEM_LEGACY_EMPLOYEE_COMP_DATA_FILE=employee_comp_data.json
