# Local development secrets and toggles (COMMIT-SAFE TEMPLATE)
#
# 1. Copy this file to `.env.development` in the project root (gitignored).
# 2. Set SECRET_KEY (e.g. python -c "import secrets; print(secrets.token_hex(32))")
#    and MISTRAL_API_KEY for AI features.
# 3. Run the app via the helper script so variables are exported:
#      ./scripts/with_dev_env.sh python web_app.py
#      ./scripts/with_dev_env.sh python -m wingmanem.app
#
# Do not put real keys in this example file.

SECRET_KEY=
MISTRAL_API_KEY=

WINGMANEM_WEB_DEBUG=true
WINGMANEM_WEB_HOST=127.0.0.1
WINGMANEM_WEB_PORT=5000

# Optional CLI gate if you enable authenticate() in main
# WINGMANEM_PASSWORD=
